APP_NAME="Sơn Hà Xã Tắc Mobile"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=https://yourdomain.com

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAITHFUL_LOCALE=vi

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ----------------------------------------------------------------------
# Database chính (account) - MariaDB/MySQL
# DB_HOST: IP của MariaDB server (ví dụ: 127.0.0.1)
# ----------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=MARIADB_HOST
DB_PORT=3306
DB_DATABASE=account
DB_USERNAME=YOUR_USERNAME
DB_PASSWORD=YOUR_PASSWORD

# ----------------------------------------------------------------------
# Database tin tức (jxm_news) - MariaDB/MySQL
# Nếu cùng server thì DB_NEWS_HOST giống DB_HOST
# ----------------------------------------------------------------------
DB_NEWS_CONNECTION=mysql
DB_NEWS_HOST=MARIADB_HOST
DB_NEWS_PORT=3306
DB_NEWS_DATABASE=jxm_news
DB_NEWS_USERNAME=YOUR_USERNAME
DB_NEWS_PASSWORD=YOUR_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

